{
    "files.exclude": {
        "**/node_modules/**/android": true,
        "**/node_modules/**/ios": true,
        "**/android/app/build": true,
        "**/android/.gradle": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/android/app/build": true,
        "**/android/.gradle": true
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/android/app/build/**": true,
        "**/android/.gradle/**": true
    },
    "java.import.exclusions": [
        "**/node_modules/**",
        "**/android/app/build/**",
        "**/android/.gradle/**"
    ],
    "java.compile.nullAnalysis.mode": "disabled",
    "java.configuration.updateBuildConfiguration": "automatic",
    "java.jdt.ls.java.home": "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home",
    "gradle.java.home": "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home",
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-21",
            "path": "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home",
            "default": true
        }
    ],
    "css.lint.unknownAtRules": "ignore"
}