{
  "expo": {
    "name": "Nexara",
    "slug": "nexara",
    "scheme": "nexara",
    "version": "1.1.23",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.promenar.nexara",
      "versionCode": 23,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you set assistant avatars.",
          "cameraPermission": "The app accesses your camera to let you take assistant avatars."
        }
      ],
      "./plugins/withCustomApkName",
      "./plugins/withAndroidDebugConfig",
      "./plugins/withWideColorGamut",
      "expo-asset",
      "./plugins/withForegroundService"
    ]
  }
}